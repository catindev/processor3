{
  "mappingId": "mappings.fl_resident.validation_facts",
  "sources": {
    "validation": "object"
  },
  "output": {
    "resolutionClass": {
      "mapValue": {
        "from": "sources.validation.status",
        "map": {
          "EXCEPTION": "COMPLIANCE_REJECT",
          "ERROR": "VALIDATION_REJECT",
          "OK": "CONTINUE",
          "OK_WITH_WARNINGS": "CONTINUE"
        },
        "fallback": "UNKNOWN"
      }
    },
    "responseMode": {
      "mapValue": {
        "from": "sources.validation.status",
        "map": {
          "EXCEPTION": "GENERALIZED_ERROR",
          "ERROR": "DETAILED_ERRORS",
          "OK": "SUCCESS",
          "OK_WITH_WARNINGS": "SUCCESS"
        },
        "fallback": "UNKNOWN"
      }
    },
    "reasonCode": {
      "mapValue": {
        "from": "sources.validation.status",
        "map": {
          "EXCEPTION": "REGULATORY_REJECT",
          "ERROR": "VALIDATION_ERROR",
          "OK": "VALIDATION_OK",
          "OK_WITH_WARNINGS": "VALIDATION_WARNING"
        },
        "fallback": "UNKNOWN"
      }
    },
    "merchantMessage": {
      "mapValue": {
        "from": "sources.validation.status",
        "map": {
          "EXCEPTION": "Заявка отклонена по регуляторной причине",
          "ERROR": "Заявка отклонена. Есть ошибки",
          "OK": "Проверки заявки пройдены",
          "OK_WITH_WARNINGS": "Проверки заявки пройдены"
        },
        "fallback": "Результат проверки заявки не определён"
      }
    },
    "merchantErrorList": {
      "from": "sources.validation.issues"
    },
    "hasErrors": {
      "equals": [
        "sources.validation.status",
        "ERROR"
      ]
    },
    "hasWarnings": {
      "equals": [
        "sources.validation.status",
        "OK_WITH_WARNINGS"
      ]
    },
    "hasExceptions": {
      "equals": [
        "sources.validation.status",
        "EXCEPTION"
      ]
    }
  },
  "name": "Факты валидации заявки",
  "description": "Преобразует результат проверки заявки в устойчивые признаки и merchant-поля."
}
